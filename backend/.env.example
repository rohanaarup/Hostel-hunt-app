# ROHII Hostel Hunt — Django Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Django Core
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# Database (SQLite for dev — change to postgres for production)
# DATABASE_URL=postgres://user:password@localhost:5432/rohii_db

# CORS — origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8000

# Email — set EMAIL_BACKEND=console for dev (OTP prints to terminal)
# For production, set to smtp and fill in SMTP settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=ROHII Hostel Hunt <your-gmail@gmail.com>

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
